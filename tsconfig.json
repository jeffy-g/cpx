{
    "compilerOptions": {
        "newLine": "lf",
        "skipDefaultLibCheck": true,
        "skipLibCheck": true,
        "allowJs": true,
        "checkJs": true,
        "strict": true,
        "removeComments": false,
        "moduleResolution": "node10",
        "target": "esnext",
        "module": "commonjs",
        "sourceMap": false,
        "outDir": "./build/",
        "paths": {
            "*": ["./*"]
        },
        "diagnostics": true,
        "declaration": true
    },
    "include": [
        "./bin/**/*",
        "./lib/**/*",
        "./test/**/*.js"
    ]
}
